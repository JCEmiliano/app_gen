import 'package:flutter/material.dart';

void main() {
  runApp(const MyApp());
}

class MyApp extends StatefulWidget {
  const MyApp({super.key});

  @override
  State<MyApp> createState() => _MyAppState();
}

class _MyAppState extends State<MyApp> {
  // Estado para el modo oscuro
  bool isDarkMode = true;

  void toggleTheme() {
    setState(() {
      isDarkMode = !isDarkMode;
    });
  }

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      title: 'FieldFlow Generador',
      themeMode: isDarkMode ? ThemeMode.dark : ThemeMode.light,
      theme: _buildTheme(false),
      darkTheme: _buildTheme(true),
      home: GeneratorScreen(
        onToggleTheme: toggleTheme,
      ),
    );
  }

  ThemeData _buildTheme(bool isDark) {
    // Definimos los colores basados en la paleta de Tailwind proporcionada
    final surface = isDark ? const Color(0xFF080e1c) : const Color(0xFFf8f9fc);
    final onSurface = isDark ? const Color(0xFFe0e5f9) : const Color(0xFF1a1c23);
    final primary = isDark ? const Color(0xFF85adff) : const Color(0xFF005bc4);
    
    return ThemeData(
      brightness: isDark ? Brightness.dark : Brightness.light,
      scaffoldBackgroundColor: surface,
      colorScheme: ColorScheme(
        brightness: isDark ? Brightness.dark : Brightness.light,
        primary: primary,
        onPrimary: isDark ? const Color(0xFF002c66) : const Color(0xFFffffff),
        secondary: isDark ? const Color(0xFF69f6b8) : const Color(0xFF006c49),
        onSecondary: isDark ? const Color(0xFF005a3c) : const Color(0xFFffffff),
        error: const Color(0xFFff716c),
        onError: const Color(0xFF490006),
        surface: surface,
        onSurface: onSurface,
      ),
      appBarTheme: AppBarTheme(
        backgroundColor: surface,
        elevation: 0,
        iconTheme: IconThemeData(color: primary),
      ),
      useMaterial3: true,
    );
  }
}

